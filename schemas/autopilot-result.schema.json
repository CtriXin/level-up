{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctrixin.local/level-up/autopilot-result.schema.json",
  "title": "LevelUpAutopilotResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "runId",
    "status",
    "stopReason",
    "rounds"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "runId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "adapted",
        "stopped"
      ]
    },
    "stopReason": {
      "type": "string",
      "enum": [
        "rounds-exhausted",
        "budget-exhausted",
        "no-improvement",
        "round-timeout",
        "blocked"
      ]
    },
    "budgetMs": {
      "type": [
        "integer",
        "null"
      ]
    },
    "elapsedMs": {
      "type": "integer"
    },
    "noImprovementRounds": {
      "type": "integer"
    },
    "rounds": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "round",
          "candidateId",
          "decision",
          "score",
          "commit",
          "changed",
          "blocked",
          "runner",
          "apply",
          "validation",
          "review",
          "strategy",
          "evaluation"
        ],
        "properties": {
          "round": {
            "type": "integer"
          },
          "candidateId": {
            "type": "string"
          },
          "decision": {
            "type": "string",
            "enum": [
              "keep",
              "discard"
            ]
          },
          "score": {
            "type": "number"
          },
          "commit": {
            "type": "string"
          },
          "changed": {
            "type": "boolean"
          },
          "blocked": {
            "type": "boolean"
          },
          "runner": {
            "type": "object"
          },
          "apply": {
            "type": [
              "object",
              "null"
            ]
          },
          "validation": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "review": {
            "type": "object"
          },
          "strategy": {
            "type": "object"
          },
          "evaluation": {
            "type": "object"
          }
        }
      }
    },
    "prPack": {
      "type": [
        "object",
        "null"
      ]
    },
    "stateCore": {
      "type": [
        "object",
        "null"
      ]
    },
    "report": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
