{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctrixin.local/level-up/pr-pack.schema.json",
  "title": "LevelUpPrPack",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "runId", "createdAt", "outputDir", "visualMode", "files"],
  "properties": {
    "version": { "type": "string" },
    "runId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "minLength": 1 },
    "outputDir": { "type": "string", "minLength": 1 },
    "reviewerBot": {
      "type": ["string", "null"]
    },
    "visualMode": { "type": "boolean" },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prBody", "bugReview", "visualEvidence", "manifest"],
      "properties": {
        "prBody": { "type": "string", "minLength": 1 },
        "bugReview": { "type": "string", "minLength": 1 },
        "visualEvidence": { "type": "string", "minLength": 1 },
        "manifest": { "type": "string", "minLength": 1 }
      }
    }
  }
}
